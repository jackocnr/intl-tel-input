{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    // Resolve the `intl-tel-input` package name to source rather than dist,
    // so the IDE and build stay accurate regardless of `dist/` state.
    "paths": {
      "intl-tel-input": ["../src/js/intlTelInput.ts"],
      "intl-tel-input/utils": ["../src/js/types/utils.d.ts"]
    },
    /* Linting */
    "strict": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.d.ts"],
}