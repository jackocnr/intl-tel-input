// Used by the IDE (via reference from tsconfig.json) and by vite-plugin-dts
// during `build:vue`. vite-plugin-dts is what actually emits the .d.ts files
// into vue/dist — plain tsc is never run against this config by the build.
// Unlike the other wrappers, this extends @vue/tsconfig (Vue's ecosystem
// base) rather than ../tsconfig.base.json. @vue/tsconfig already provides
// the equivalent settings (strict, bundler resolution, esModuleInterop,
// etc.) plus Vue-specific defaults (jsx, verbatimModuleSyntax), so layering
// our base on top would be redundant.
{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    // Resolve to dist rather than source (unlike svelte). Source-path mapping
    // pulls ../src/js files into the program and trips TS6059 against
    // rootDir: "src", and removing rootDir breaks vite-plugin-dts's emit
    // layout (entry files end up flagged as "Outside emitted").
    "paths": {
      "intl-tel-input": ["../dist/js/intlTelInput.d.ts"]
    },
    /* Linting */
    "strict": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.d.ts"],
}