{
  "name": "iti-website",
  "version": "1.0.0",
  "description": "The website for intl-tel-input",
  "type": "module",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "chokidar": "^5.0.0",
    "clean-css-cli": "^5.6.3",
    "esbuild": "^0.28.0",
    "lodash.template": "^4.18.1",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "rimraf": "^6.1.3",
    "zone.js": "^0.16.1"
  },
  "scripts": {
    "watch": "node scripts/watch.js",
    "clean": "rimraf build tmp",
    "fetch-stats": "node scripts/fetch-stats.js",
    "fetch-stats:prod": "node scripts/fetch-stats.js --env=prod",
    "copy": "node scripts/copy-assets.js",
    "build:css:sass": "sass --no-source-map src/css/website.scss:build/css/website.css src/css/large_flags_overrides.scss:build/css/large_flags_overrides.css src/css/highlightjs_overrides.scss:build/css/highlightjs_overrides.css src/css/playground.scss:build/css/playground.css src/css/docs.scss:build/css/docs.css src/css/homepage.scss:build/css/homepage.css",
    "build:css:cache-bust": "node scripts/build-pages.js --task=website_css,large_flags_overrides_css,homepage_css,docs_css,playground_css",
    "build:css:min": "cleancss -o build/css/website.css build/css/website.css && cleancss -o build/css/playground.css build/css/playground.css && cleancss -o build/css/homepage.css build/css/homepage.css && cleancss -o build/css/docs.css build/css/docs.css",
    "build:css": "npm run build:css:sass && npm run build:css:cache-bust && npm run build:css:min",
    "build:esbuild:templates": "node scripts/build-pages.js --task=lookup_country_js,right_to_left_js,angular_component_js,react_component_js,playground_js",
    "build:esbuild": "npm run build:esbuild:templates && node scripts/esbuild.js",
    "build:vue": "node scripts/build-pages.js --task=vue_component_js && vite build --config src/examples/js/viteVueDemo.config.js",
    "build:svelte": "node scripts/build-pages.js --task=svelte_component_js && vite build --config src/examples/js/viteSvelteDemo.config.js",
    "build:pages": "node scripts/build-pages.js",
    "build:pages:prod": "node scripts/build-pages.js --env=prod",
    "replace": "node scripts/replace-validation-precise.js",
    "strip-comments": "node scripts/strip-html-comments.js",
    "build": "npm run clean && npm run fetch-stats && npm run copy && npm run build:css && npm run build:esbuild && npm run build:vue && npm run build:svelte && npm run build:pages && npm run replace && npm run strip-comments",
    "build:prod": "npm run clean && npm run fetch-stats:prod && npm run copy && npm run build:css && npm run build:esbuild && npm run build:vue && npm run build:svelte && npm run build:pages:prod && npm run replace && npm run strip-comments"
  }
}
