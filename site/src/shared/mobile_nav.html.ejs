<aside class="iti-mobile-nav d-lg-none">
  <div class="offcanvas offcanvas-start" tabindex="-1" id="itiMobileNav" aria-labelledby="itiMobileNavLabel">
    <div class="offcanvas-header border-bottom">
      <h5 class="offcanvas-title" id="itiMobileNavLabel">
        <a class="d-flex align-items-center" href="/">
          <img src="/img/logo-white.png" alt="intl-tel-input logo" width="25" height="25" class="iti-logo">
          intl-tel-input
        </a>
      </h5>
      <button
        type="button"
        class="btn-close btn-close-white"
        data-bs-dismiss="offcanvas"
        data-bs-target="#itiMobileNav"
        aria-label="Close navigation menu"
      ></button>
    </div>
    <div class="offcanvas-body flex-column">

      <ul class="flex-column flex-nowrap nav nav-pills nav--primary-links" id="itiMobilePrimaryNav">
        <li class="nav-item">
          <button
            type="button"
            class="nav-link iti-nav-toggle text-start w-100 d-flex align-items-center"
            data-bs-toggle="collapse"
            data-bs-target="#itiMobileDocsMenu"
            aria-controls="itiMobileDocsMenu"
            aria-expanded="<%= pageType === 'docs' ? 'true' : 'false' %>"
          >
            <span class="d-flex align-items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="bi bi-book-half"
                style="color: rgb(53 217 184)"
                viewBox="0 0 16 16"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8.5 2.687c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783" />
              </svg>
              <span class="d-inline-flex align-items-center gap-1">
                Docs
                <span class="iti-nav-chevron" aria-hidden="true"></span>
              </span>
            </span>
          </button>
          <ul
            class="iti-nav-submenu collapse nav flex-column flex-nowrap nav-pills ms-4 mb-2 <% if (pageType === 'docs') { %>show<% } %>"
            id="itiMobileDocsMenu"
            data-bs-parent="#itiMobilePrimaryNav"
          >
            <% docsDropdownPages.forEach((p) => { %>
              <li class="nav-item<% if (p.nested) { %> iti-nav-item--nested<% } %>">
                <a class="nav-link py-2 <% if (pageType === 'docs' && name === p.name) { %>active<% } %>" href="<%= p.href %>"><%= p.label %></a>
              </li>
            <% }); %>
          </ul>
        </li>

        <li class="nav-item">
          <a class="nav-link d-flex align-items-center gap-2" href="/playground">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-joystick"
              style="color: rgb(230 68 134)"
              viewBox="0 0 16 16"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M10 2a2 2 0 0 1-1.5 1.937v5.087c.863.083 1.5.377 1.5.726 0 .414-.895.75-2 .75s-2-.336-2-.75c0-.35.637-.643 1.5-.726V3.937A2 2 0 1 1 10 2" />
              <path d="M0 9.665v1.717a1 1 0 0 0 .553.894l6.553 3.277a2 2 0 0 0 1.788 0l6.553-3.277a1 1 0 0 0 .553-.894V9.665c0-.1-.06-.19-.152-.23L9.5 6.715v.993l5.227 2.178a.125.125 0 0 1 .001.23l-5.94 2.546a2 2 0 0 1-1.576 0l-5.94-2.546a.125.125 0 0 1 .001-.23L6.5 7.708l-.013-.988L.152 9.435a.25.25 0 0 0-.152.23" />
            </svg>
            Playground
          </a>
        </li>

        <li class="nav-item">
          <button
            type="button"
            class="nav-link iti-nav-toggle text-start w-100 d-flex align-items-center"
            data-bs-toggle="collapse"
            data-bs-target="#itiMobileExamplesMenu"
            aria-controls="itiMobileExamplesMenu"
            aria-expanded="<%= pageType === 'examples' ? 'true' : 'false' %>"
          >
            <span class="d-flex align-items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="bi bi-code-square"
                style="color: rgb(222 159 74)"
                viewBox="0 0 16 16"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                <path d="M6.854 4.646a.5.5 0 0 1 0 .708L4.207 8l2.647 2.646a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 0 1 .708 0m2.292 0a.5.5 0 0 0 0 .708L11.793 8l-2.647 2.646a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708 0" />
              </svg>
              <span class="d-inline-flex align-items-center gap-1">
                Examples
                <span class="iti-nav-chevron" aria-hidden="true"></span>
              </span>
            </span>
          </button>
          <ul
            class="iti-nav-submenu collapse nav flex-column flex-nowrap nav-pills ms-4 mb-2 <% if (pageType === 'examples') { %>show<% } %>"
            id="itiMobileExamplesMenu"
            data-bs-parent="#itiMobilePrimaryNav"
          >
            <% examplesDropdownSections.forEach((section) => {
                 const isActive = pageType === 'examples' && section.items.some((p) => p.name === name);
                 const isExpanded = isActive || (pageType !== 'examples' && section.name === "javascript_plugin");
                 const collapseId = `itiMobileExamples-${section.name}`;
            %>
              <li class="nav-item iti-nav-section">
                <button
                  type="button"
                  class="iti-nav-section-toggle iti-nav-section-heading d-inline-flex align-items-center gap-1"
                  data-bs-toggle="collapse"
                  data-bs-target="#<%= collapseId %>"
                  aria-controls="<%= collapseId %>"
                  aria-expanded="<%= isExpanded ? 'true' : 'false' %>"
                >
                  <span><%= section.label %></span>
                  <span class="iti-nav-chevron" aria-hidden="true"></span>
                </button>
                <ul class="iti-nav-submenu collapse nav flex-column flex-nowrap nav-pills <% if (isExpanded) { %>show<% } %>" id="<%= collapseId %>">
                  <% section.items.forEach((p) => { %>
                    <li class="nav-item iti-nav-item--nested">
                      <a class="nav-link py-2 <% if (pageType === 'examples' && name === p.name) { %>active<% } %>" href="<%= p.href %>"><%= p.label %></a>
                    </li>
                  <% }); %>
                </ul>
              </li>
            <% }); %>
          </ul>
        </li>
      </ul>

      <hr class="border-top my-3" />

      <ul class="flex-column flex-nowrap nav nav-pills nav--primary-links">
        <li class="nav-item">
          <a
            class="nav-link d-flex align-items-center gap-2"
            href="https://github.com/jackocnr/intl-tel-input"
            rel="noopener"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 512 499.36"
              role="img"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                fill-rule="evenodd"
                d="M256 0C114.64 0 0 114.61 0 256c0 113.09 73.34 209 175.08 242.9 12.8 2.35 17.47-5.56 17.47-12.34 0-6.08-.22-22.18-.35-43.54-71.2 15.49-86.2-34.34-86.2-34.34-11.64-29.57-28.42-37.45-28.42-37.45-23.27-15.84 1.73-15.55 1.73-15.55 25.69 1.81 39.21 26.38 39.21 26.38 22.84 39.12 59.92 27.82 74.5 21.27 2.33-16.54 8.94-27.82 16.25-34.22-56.84-6.43-116.6-28.43-116.6-126.49 0-27.95 10-50.8 26.35-68.69-2.63-6.48-11.42-32.5 2.51-67.75 0 0 21.49-6.88 70.4 26.24a242.65 242.65 0 0 1 128.18 0c48.87-33.13 70.33-26.24 70.33-26.24 14 35.25 5.18 61.27 2.55 67.75 16.41 17.9 26.31 40.75 26.31 68.69 0 98.35-59.85 120-116.88 126.32 9.19 7.9 17.38 23.53 17.38 47.41 0 34.22-.31 61.83-.31 70.23 0 6.85 4.61 14.81 17.6 12.31C438.72 464.97 512 369.08 512 256.02 512 114.62 397.37 0 256 0z"
              ></path>
            </svg>
            Github
          </a>
        </li>
      </ul>
    </div>
  </div>
</aside>
