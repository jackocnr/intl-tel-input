<nav class="iti-breadcrumb" aria-label="Breadcrumb">
  <ol class="iti-breadcrumb__list">
    <li class="iti-breadcrumb__item" aria-current="page">Examples »</li>
  </ol>
</nav>

<h1><%= content_title %></h1>

<div class="section">
  <% if (desc.charAt(0) === '<') { %>
    <%= desc %>
  <% } else { %>
    <p><%= desc %></p>
  <% } %>
</div>

<div class="section demo" <% if (typeof isRtl !== 'undefined') { %>dir="rtl"<% } %>>
  <h2>Demo</h2>
  <% if (typeof demo_note !== 'undefined') { %>
    <%= demo_note %>
  <% } %>
  <%= markup %>
</div>

<% if (typeof hideMarkupSection === 'undefined') { %>
<div class="section">
  <h2>Html</h2>
  <pre><code class="language-html"><%- display_markup %></code></pre>
</div>
<% } %>

<div class="section">
  <h2>JavaScript</h2>
  <% if (typeof notesHtml !== 'undefined' && notesHtml) { %>
    <%= notesHtml %>
  <% } %>
  <pre><code class="language-javascript"><%- display_code %></code></pre>
</div>

<%= common_body_end %>
<% if (typeof iti_script !== 'undefined') { %>
  <%= iti_script %>
<% } %>
<script src="<%= cacheBust('/examples/js/' + script) %>"></script>
