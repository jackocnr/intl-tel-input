{
  // IDE-only config so Svelte's type-checker can resolve "intl-tel-input"
  // (via the workspace package.json `exports`) from inside .svelte files.
  // Not used by any build — svelte components are exported as source.
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
