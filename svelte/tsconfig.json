{
  // Used by the IDE for type-checking .svelte files.
  "compilerOptions": {
    "strict": true,
    "target": "ES2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["svelte"],
    // Resolve the `intl-tel-input` package name to source rather than dist,
    // so the IDE stays accurate even when `dist/` has been cleaned.
    "paths": {
      "intl-tel-input": ["../src/js/intlTelInput.ts"],
      "intl-tel-input/utils": ["../src/js/types/utils.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
