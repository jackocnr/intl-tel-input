{
  // Used by the IDE for type-checking .svelte files.
  "compilerOptions": {
    "strict": true,
    "target": "ES2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
