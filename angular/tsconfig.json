// IDE-only config: provides IntelliSense / type-checking for angular/src.
// Resolves "intl-tel-input" to source rather than dist so the IDE stays
// accurate regardless of whether dist/ has been built. Deliberately
// `noEmit: true` and without rootDir — setting rootDir would trip TS6059
// when source-path resolution pulls ../src/js files into the program, and
// the IDE has no emit anyway. See tsconfig.build.json (same directory)
// for the build-side config used by ngc.
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // "node" is needed because the source-path mapping below pulls
    // src/js/intlTelInput.ts into the program and it references
    // process.env.VERSION.
    "types": ["node"],
    "paths": {
      "intl-tel-input": ["../src/js/intlTelInput.ts"],
      "intl-tel-input/utils": ["../src/js/types/utils.d.ts"]
    }
  }
}
