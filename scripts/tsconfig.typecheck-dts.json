    "strict": true,
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": false,
    "noEmit": true,
    "types": [],
    "lib": ["ES2022", "DOM"],
    "paths": {
