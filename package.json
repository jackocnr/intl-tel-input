{
  "name": "intl-tel-input",
  "version": "26.9.2",
  "description": "A JavaScript plugin for entering and validating international telephone numbers",
  "type": "module",
  "license": "MIT",
  "author": "Jack O'Connor (http://jackocnr.com)",
  "scripts": {
    "test": "npm run test:js && npm run test:e2e",
    "test:js": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:linux": "./scripts/playwright-linux-docker.sh",
    "test:e2e:linux:update": "./scripts/playwright-linux-docker.sh --update-snapshots",
    "lint:js": "eslint .",
    "watch": "grunt watch",
    "build": "grunt build",
    "build:js": "grunt build:js",
    "build:jsfast": "grunt build:jsfast",
    "build:translations": "grunt build:translations",
    "build:utils": "grunt build:utils",
    "build:css": "grunt build:css",
    "build:img": "grunt build:img",
    "build:react": "grunt build:react",
    "build:vue": "grunt build:vue",
    "build:angular": "grunt build:angular",
    "build:test": "npm run build:js && npm run test",
    "prepublishOnly": "grunt build",
    "vue:demo": "vite --config vue/demo/validation/vite.config.js",
    "svelte:demo": "vite --config svelte/demo/validation/vite.config.mjs"
  },
  "devDependencies": {
    "@angular/common": "^19.2.20",
    "@angular/compiler": "^19.2.20",
    "@angular/compiler-cli": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/forms": "^19.2.20",
    "@angular/platform-browser": "^19.2.20",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-xml-parser": "^5.2.5",
    "flag-icons": "^7.2.3",
    "globals": "^17.4.0",
    "google-closure-compiler": "^20240317.0.0",
    "google-closure-library": "^20230802.0.0",
    "grunt": "^1.6.1",
    "grunt-bump": "^0.8.0",
    "grunt-cli": "^1.2.0",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-cssmin": "^5.0.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-replace": "^2.0.2",
    "grunt-sass": "^3.0.0",
    "grunt-shell": "^4.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0",
    "load-grunt-config": "^4.0.1",
    "playwright": "^1.58.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.2",
    "sass": "^1.83.1",
    "sharp": "^0.33.5",
    "svelte": "^5.46.4",
    "time-grunt": "^2.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.2.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0",
    "zone.js": "^0.15.0"
  },
  "files": [
    "build/*",
    "react/build/*",
    "vue/build/*",
    "angular/build/*",
    "svelte/src/*",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "package-lock.json",
    "README.md",
    "index.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jackocnr/intl-tel-input.git"
  },
  "homepage": "https://intl-tel-input.com",
  "style": "build/css/intlTelInput.css",
  "main": "./build/js/intlTelInput.js",
  "types": "./build/js/intlTelInput.d.ts",
  "exports": {
    ".": {
      "types": "./build/js/intlTelInput.d.ts",
      "import": "./build/js/intlTelInput.mjs"
    },
    "./intlTelInputWithUtils": {
      "types": "./build/js/intlTelInput.d.ts",
      "import": "./build/js/intlTelInputWithUtils.mjs"
    },
    "./data": {
      "types": "./build/js/data.d.ts",
      "import": "./build/js/data.mjs"
    },
    "./utils": {
      "types": "./src/js/types/utils.d.ts",
      "import": "./build/js/utils.js"
    },
    "./react": {
      "types": "./react/build/IntlTelInput.d.ts",
      "import": "./react/build/IntlTelInput.js"
    },
    "./reactWithUtils": {
      "types": "./react/build/IntlTelInputWithUtils.d.ts",
      "import": "./react/build/IntlTelInputWithUtils.js"
    },
    "./vue": {
      "types": "./vue/build/index.d.ts",
      "import": "./vue/build/IntlTelInput.js"
    },
    "./vueWithUtils": {
      "types": "./vue/build/indexWithUtils.d.ts",
      "import": "./vue/build/IntlTelInputWithUtils.js"
    },
    "./angular": {
      "types": "./angular/build/IntlTelInput.d.ts",
      "import": "./angular/build/IntlTelInput.js"
    },
    "./angularWithUtils": {
      "types": "./angular/build/IntlTelInputWithUtils.d.ts",
      "import": "./angular/build/IntlTelInputWithUtils.js"
    },
    "./svelte": {
      "svelte": "./svelte/src/IntlTelInput.svelte",
      "import": "./svelte/src/IntlTelInput.svelte"
    },
    "./svelteWithUtils": {
      "svelte": "./svelte/src/IntlTelInputWithUtils.svelte",
      "import": "./svelte/src/IntlTelInputWithUtils.svelte"
    },
    "./i18n": {
      "types": "./build/js/i18n.d.ts",
      "import": "./build/js/i18n/index.js"
    },
    "./i18n/*": {
      "types": "./build/js/i18n.d.ts",
      "import": "./build/js/i18n/*/index.js"
    },
    "./styles": "./build/css/intlTelInput.css",
    "./*": "./*"
  },
  "typesVersions": {
    "*": {
      ".": [
        "build/js/intlTelInput.d.ts"
      ],
      "react": [
        "react/build/IntlTelInput.d.ts"
      ],
      "angular": [
        "angular/build/IntlTelInput.d.ts"
      ]
    }
  },
  "keywords": [
    "international",
    "country",
    "dial code",
    "telephone",
    "phone",
    "mobile",
    "input",
    "flag",
    "dropdown",
    "javascript",
    "plugin",
    "css",
    "html",
    "validation",
    "formatting",
    "react",
    "vue",
    "angular",
    "svelte",
    "component",
    "typescript"
  ],
  "workspaces": [
    "site"
  ]
}
