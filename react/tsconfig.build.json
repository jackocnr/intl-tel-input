// Used by `build:react` (tsc -p react/tsconfig.build.json) to emit the
// wrapper's .d.ts files. See tsconfig.json (same directory) for the IDE
// config — they deliberately differ: the IDE resolves "intl-tel-input" to
// source for dist-independence, while the build resolves to dist (via the
// package exports map) so the emitted declarations inline the bundled
// public surface.
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true, //* Generate .d.ts files.
    "emitDeclarationOnly": true, //* ONLY generate .d.ts files (we use esbuild for the actual bundling).
    "outDir": "dist",
    "rootDir": "./src",
  }
}
