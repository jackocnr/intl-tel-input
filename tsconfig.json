{
  // IDE-only config: provides IntelliSense / type-checking for src/js/.
  // Not used by the build — declarations are generated by dts-bundle-generator (see scripts/build-dts.js).
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "utils-compiled": ["./packages/core/dist/js/utils.js"]
    },
    "allowJs": true,
    "noEmit": true,
    // Don't auto-load every @types/* package — dts-bundle-generator otherwise
    // traverses unrelated types (e.g. @types/markdown-it from the site workspace) and trips on broken declarations.
    "types": ["node"],
  },
  "include": [
    "packages/core/src/js/**/*.ts",
  ],
  // Tell the Svelte language server to skip this tsconfig when looking for
  // a project that owns .svelte files (svelte/tsconfig.json owns those).
  "exclude": ["**/*.svelte"],
}
