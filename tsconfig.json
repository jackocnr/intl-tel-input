{
  // IDE-only config: provides IntelliSense / type-checking for src/js/.
  // Not used by the build — declarations are generated by dts-bundle-generator (see grunt/shell.js).
  "compilerOptions": {
    "strict": true,
    "target": "ES2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true, // required for react (etc) default imports
    "allowJs": true, // allow importing .js files e.g. utils-symlink.js
    "noEmit": true,
  },
  "include": [
    "src/js/**/*.ts",
  ],
}
