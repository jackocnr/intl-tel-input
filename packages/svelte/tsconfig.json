{
  // Used by the IDE for type-checking .svelte files.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Svelte 5 component sources use syntax that needs a newer target than the base.
    "target": "ES2024",
    "skipLibCheck": true,
    "allowJs": true,
    // "node" is needed because the source-path mapping below pulls src/js/intlTelInput.ts
    // into svelte-check's program, and that file references process.env.VERSION.
    "types": ["svelte", "node"],
    // Resolve the `intl-tel-input` package name to source rather than dist,
    // so the IDE stays accurate even when `dist/` has been cleaned.
    "paths": {
      "intl-tel-input": ["../core/src/js/intlTelInput.ts"],
      "intl-tel-input/utils": ["../core/src/js/types/utils.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
