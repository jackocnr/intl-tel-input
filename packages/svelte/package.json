{
  "name": "@intl-tel-input/svelte",
  "version": "28.0.2",
  "description": "A Svelte component for intl-tel-input, for entering, formatting, and validating international telephone numbers",
  "type": "module",
  "license": "MIT",
  "author": "Jack O'Connor (http://jackocnr.com)",
  "types": "./src/IntlTelInput.svelte.d.ts",
  "exports": {
    ".": {
      "types": "./src/IntlTelInput.svelte.d.ts",
      "svelte": "./src/IntlTelInput.svelte",
      "import": "./src/IntlTelInput.svelte"
    },
    "./with-utils": {
