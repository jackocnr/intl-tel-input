// IDE-only config: provides IntelliSense / type-checking for react/src.
// Differs from tsconfig.build.json (same directory) by resolving
// "intl-tel-input" to source rather than dist, so the IDE stays accurate
// regardless of whether dist/ has been built. Deliberately `noEmit: true`
// and without rootDir: setting rootDir would trip TS6059 when source-path
// resolution pulls ../src/js files into the program, and dropping rootDir
// without dropping emit would break tsc's output layout (see
// tsconfig.build.json where emit happens and rootDir is required).
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // "node" is needed because the source-path mapping below pulls
    // src/js/intlTelInput.ts into the program and it references
    // process.env.VERSION. "react" is included so JSX / React types
    // resolve (would be auto-included without an explicit `types` list,
    // but we've narrowed it to keep the surface predictable).
    "types": ["node", "react"],
    "paths": {
      "intl-tel-input": ["../core/src/js/intlTelInput.ts"],
      "intl-tel-input/utils": ["../core/src/js/types/utils.d.ts"]
    }
  }
}
